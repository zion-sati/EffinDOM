[binaries]
c = '@EFFINDOM_HARFBUZZ_APPLE_C_COMPILER@'
cpp = '@EFFINDOM_HARFBUZZ_APPLE_CPP_COMPILER@'
ar = '@EFFINDOM_HARFBUZZ_APPLE_ARCHIVER@'

[host_machine]
system = 'darwin'
cpu_family = '@EFFINDOM_HARFBUZZ_APPLE_CPU_FAMILY@'
cpu = '@EFFINDOM_HARFBUZZ_APPLE_CPU@'
endian = 'little'

[properties]
needs_exe_wrapper = true

[built-in options]
c_args = ['-arch', '@EFFINDOM_HARFBUZZ_APPLE_ARCH@']
cpp_args = ['-arch', '@EFFINDOM_HARFBUZZ_APPLE_ARCH@']
c_link_args = ['-arch', '@EFFINDOM_HARFBUZZ_APPLE_ARCH@']
cpp_link_args = ['-arch', '@EFFINDOM_HARFBUZZ_APPLE_ARCH@']
